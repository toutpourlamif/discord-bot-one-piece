{
  "name": "@one-piece/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "sh -c 'drizzle-kit generate ${1:+--name=\"$1\"}' --",
    "migrate": "tsx --env-file=.env.local src/migrate.ts",
    "regen": "tsx scripts/regen-migration.ts",
    "seed": "tsx --env-file=.env.local src/seed.ts",
    "studio": "tsx scripts/studio.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "open": "^11.0.0",
    "tsx": "^4.21.0"
  }
}
