{
  "name": "discord-bot-one-piece",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm -F @one-piece/bot dev",
    "typecheck": "pnpm -r typecheck",
    "docker:run": "docker compose up",
    "db:generate": "pnpm -F @one-piece/db generate",
    "db:migrate": "pnpm -F @one-piece/db migrate",
    "db:studio": "pnpm -F @one-piece/db studio"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
