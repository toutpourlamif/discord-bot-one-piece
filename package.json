{
  "name": "discord-bot-one-piece",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm -F @one-piece/bot dev",
    "tc": "pnpm typecheck",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docker:run": "docker compose up",
    "db:m:g": "pnpm db:migrations:generate",
    "db:m:a": "pnpm db:migrations:apply",
    "db:migrations:generate": "pnpm -F @one-piece/db generate",
    "db:migrations:apply": "pnpm -F @one-piece/db migrate",
    "db:seed": "pnpm -F @one-piece/db seed",
    "db:s": "pnpm db:studio",
    "db:studio": "pnpm -F @one-piece/db studio",
    "db:wipe": "docker exec one-piece-db psql -U one_piece -d postgres -c \"DROP DATABASE IF EXISTS one_piece WITH (FORCE)\" -c \"CREATE DATABASE one_piece\"",
    "db:r": "pnpm db:reset",
    "db:reset": "pnpm db:wipe && pnpm db:m:a && pnpm db:seed",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  }
}
